# ============================================================
# GuardianHer AI — Environment Variables Template
# IBM Hackathon 2025
# ============================================================
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to git.
# ============================================================

# -- Application ----------------------------------------------
APP_ENV=development                     # development | production
APP_SECRET_KEY=replace-with-random-32-char-string
LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR

# -- IBM watsonx.ai -------------------------------------------
WATSONX_API_KEY=your-watsonx-api-key
WATSONX_PROJECT_ID=your-project-id
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_MODEL_ID=guardianher-threat-scorer-v1

# -- IBM Watson NLP -------------------------------------------
WATSON_NLP_API_KEY=your-watson-nlp-api-key
WATSON_NLP_URL=https://api.us-south.natural-language-understanding.watson.cloud.ibm.com

# -- IBM Watson Speech-to-Text --------------------------------
WATSON_STT_API_KEY=your-watson-stt-api-key
WATSON_STT_URL=https://api.us-south.speech-to-text.watson.cloud.ibm.com

# -- IBM Watson Text-to-Speech --------------------------------
WATSON_TTS_API_KEY=your-watson-tts-api-key
WATSON_TTS_URL=https://api.us-south.text-to-speech.watson.cloud.ibm.com

# -- IBM Watson Assistant -------------------------------------
WATSON_ASSISTANT_API_KEY=your-assistant-api-key
WATSON_ASSISTANT_URL=https://api.us-south.assistant.watson.cloud.ibm.com
WATSON_ASSISTANT_ID=your-assistant-id
WATSON_ASSISTANT_VERSION=2024-08-25

# -- IBM Cloud Object Storage ---------------------------------
IBM_COS_API_KEY=your-cos-api-key
IBM_COS_SERVICE_CRN=your-service-crn
IBM_COS_AUTH_ENDPOINT=https://iam.cloud.ibm.com/identity/token
IBM_COS_ENDPOINT=https://s3.us-south.cloud-object-storage.appdomain.cloud
IBM_COS_BUCKET_NAME=guardianher-evidence

# -- IBM IoT Platform -----------------------------------------
IBM_IOT_ORG_ID=your-org-id
IBM_IOT_API_KEY=your-iot-api-key
IBM_IOT_AUTH_TOKEN=your-iot-auth-token

# -- IBM App ID -----------------------------------------------
IBM_APP_ID_TENANT_ID=your-tenant-id
IBM_APP_ID_CLIENT_ID=your-client-id
IBM_APP_ID_SECRET=your-app-id-secret
IBM_APP_ID_OAUTH_URL=https://us-south.appid.cloud.ibm.com/oauth/v4

# -- Twilio ---------------------------------------------------
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# -- Firebase (FCM Push Notifications) ------------------------
FIREBASE_CREDENTIALS_PATH=./config/firebase_credentials.json

# -- HERE Maps ------------------------------------------------
HERE_API_KEY=your-here-api-key
HERE_ROUTING_URL=https://router.hereapi.com/v8/routes

# -- Database -------------------------------------------------
DATABASE_PATH=./data/guardianher.db     # SQLite file path (prototype)
DATABASE_ENCRYPTION_KEY=replace-with-32-char-encryption-key

# -- Feature Flags (set true/false) ---------------------------
ENABLE_MOCK_SENSORS=true                # Use simulated biometric data for demo
ENABLE_MOCK_BLE=true                    # Skip BLE scan, use phone sensors
ENABLE_SMS_ALERTS=false                 # Set true to send real SMS (costs money)
ENABLE_VOICE_CALLS=false                # Set true to enable Twilio auto-call
ENABLE_AI_FAIRNESS_AUDIT=true           # Run AIF360 bias monitoring
ENABLE_WATSON_ASSISTANT=true            # Enable post-incident chatbot
